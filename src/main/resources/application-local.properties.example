server.port=8080
server.ssl.enabled=false
server.ssl.key-store=classpath:local-dev.p12
server.ssl.key-store-password=change-me
server.ssl.key-store-type=PKCS12
server.ssl.key-alias=local

spring.datasource.url=jdbc:mysql://localhost:3306/moa?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
spring.datasource.username=moa_user
spring.datasource.password=change-me

app.frontend-url=http://localhost:5173
app.email.verify-base-url=http://localhost:5173

app.cors.allowed-origins=http://localhost:5173

oauth.kakao.redirect-uri=http://localhost:5173/oauth/kakao/callback
oauth.google.redirect-uri=http://localhost:5173/oauth/google/callback

server.servlet.session.cookie.same-site=Lax
server.servlet.session.cookie.secure=false

logging.charset.console=UTF-8
logging.charset.file=UTF-8
